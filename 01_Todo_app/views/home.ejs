<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/output.css">
    <title>Document</title>
</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center">

    <div class="w-full max-w-xl bg-white shadow-lg rounded-lg p-6">

        <!-- Heading -->
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">
            Todo List
        </h1>

        <!-- Form -->
        <form action="/submit" method="POST" class="flex gap-2 mb-6">
            <input type="text" name="Work" required placeholder="Enter your task..."
                class="flex-1 px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">
            <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition">
                Add
            </button>
        </form>

        <!-- Todo List -->
        <ul class="space-y-3">

            <% if (todos.length===0) { %>
                <p class="text-center text-gray-500">No todos yet</p>
                <% } else { %>

                    <% todos.forEach(todo=> { %>
                        <li
                            class="flex justify-between items-center bg-gray-50 border px-4 py-2 rounded-lg shadow-sm hover:shadow-md transition">

                            <!-- Todo text -->
                            <span
                                class="<%= todo.completed ? 'line-through text-gray-400' : 'text-gray-700 font-medium' %>">
                                <%= todo.title %>
                            </span>

                            <!-- Buttons -->
                            <div class="flex gap-2">

                                <!-- DONE / TOGGLE -->
                                <form action="/toggle/<%= todo._id %>" method="POST">
                                    <button class="flex items-center gap-1 px-3 py-1 text-sm font-medium text-white rounded-full transition 
                            <%= todo.completed 
                                ? 'bg-yellow-500 hover:bg-yellow-600' 
                                : 'bg-green-500 hover:bg-green-600' %>">

                                        <%= todo.completed ? "Undo" : "Done" %>
                                    </button>
                                </form>

                                <!-- DELETE -->
                                <form action="/delete/<%= todo._id %>" method="POST">
                                    <button
                                        class="flex items-center gap-1 px-3 py-1 text-sm font-medium text-white bg-red-500 rounded-full hover:bg-red-600 transition">
                                        Delete
                                    </button>
                                </form>

                            </div>

                        </li>
                        <% }) %>

                            <% } %>

        </ul>

    </div>

</body>

</html>